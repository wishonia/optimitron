# Ensure consistent line endings across platforms
* text=auto

# Shell scripts must always use LF (bash won't run with CRLF)
*.sh text eol=lf
.husky/* text eol=lf

# Keep these as LF too
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
