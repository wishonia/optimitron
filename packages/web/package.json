{
  "name": "@optimitron/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ensure-env": "node scripts/ensure-env.js",
    "build:db-client": "pnpm --dir ../.. --filter @optimitron/db prisma:generate",
    "build:workspace-deps": "pnpm --dir ../.. -r --filter @optimitron/db --filter @optimitron/optimizer --filter @optimitron/wishocracy --filter @optimitron/opg --filter @optimitron/obg --filter @optimitron/data --filter @optimitron/chat-ui --filter @optimitron/storage --filter @optimitron/hypercerts --filter @optimitron/wishonia-widget build",
    "kill-port": "node -e \"try{require('child_process').execSync('npx kill-port 3001',{stdio:'ignore'})}catch{}\"",
    "dev": "pnpm run kill-port && pnpm run ensure-env && pnpm run build:workspace-deps && next dev --port 3001 --turbopack",
    "build": "pnpm run ensure-env && pnpm run build:workspace-deps && next build",
    "start": "pnpm run ensure-env && next start",
    "sync:alignment-politicians": "tsx scripts/sync-alignment-politicians.ts",
    "generate:government-size": "pnpm --dir ../examples run generate:government-size",
    "sync:government-size": "tsx scripts/sync-government-size-analysis.ts",
    "refresh:government-size": "pnpm run generate:government-size && pnpm run sync:government-size",
    "lint": "next lint",
    "typecheck": "pnpm run build:workspace-deps && tsc --noEmit",
    "test": "pnpm exec vitest run",
    "generate": "tsx scripts/generate-web-data.ts",
    "fetch": "tsx scripts/fetch-and-generate.ts",
    "causal": "tsx scripts/generate-causal-reports.ts",
    "generate:assets": "tsx scripts/generate-brand-assets.ts",
    "e2e": "node scripts/run-playwright.mjs",
    "e2e:demo": "playwright test e2e/demo-recording.spec.ts",
    "demo:narration": "tsx scripts/generate-narration.ts",
    "demo:record": "tsx scripts/record-demo.ts",
    "audit:colors": "tsx scripts/audit-colors.ts",
    "fix:colors": "tsx scripts/fix-colors.ts",
    "extract:copy": "tsx scripts/extract-copy.ts",
    "extract:tasks": "tsx scripts/extract-tasks-from-manual.ts",
    "import:treaty-model": "tsx scripts/import-treaty-policy-model.ts",
    "sync:treaty-signers": "tsx scripts/sync-treaty-signers.ts",
    "mcp:tasks": "tsx scripts/mcp-task-server.ts",
    "report:task-tree": "tsx scripts/export-task-tree.ts",
    "bootstrap:optimize-earth": "tsx scripts/bootstrap-optimize-earth.ts",
    "draft:legislation": "tsx scripts/draft-legislation.ts"
  },
