{
  "name": "@optimitron/wishonia-widget",
  "version": "0.1.0",
  "description": "Animated Wishonia character widget with lip-sync and optional chat",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./narration": "./dist/narration.js",
    "./styles": "./dist/styles/wishonia.css"
  },
  "scripts": {
    "build": "tsup src/index.ts src/narration.ts --format esm,cjs --dts --clean",
    "optimize-sprites": "tsx scripts/optimize-sprites.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@google/genai": ">=1.48.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@google/genai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@google/genai": "^1.48.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.33.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
