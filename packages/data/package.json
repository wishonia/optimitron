{
  "name": "@optimitron/data",
  "version": "0.1.0",
  "description": "Data fetchers for Optimitron - OECD, World Bank, Census, WHO, etc.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./parameters": "./src/parameters/index.ts",
    "./datasets/us-wishocratic-items": "./src/datasets/us-wishocratic-items.ts",
    "./datasets/government-report-cards": "./src/datasets/government-report-cards.ts",
    "./datasets/us-politician-scorecards": "./src/datasets/us-politician-scorecards.ts",
    "./datasets/median-income-series": "./src/datasets/median-income-series.ts",
    "./datasets/international-comparisons": "./src/datasets/international-comparisons.ts",
    "./fetchers/world-leaders": "./src/fetchers/world-leaders.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:median-income": "tsx ./scripts/generate-median-income-series.ts",
    "generate:country-panel": "tsx ./scripts/generate-country-panel.ts",
    "data:refresh": "tsx ./scripts/refresh-all.ts",
    "data:refresh:health": "tsx ./scripts/generate-health-outcomes.ts",
    "data:refresh:economic": "tsx ./scripts/generate-economic-indicators.ts",
    "data:refresh:agencies": "tsx ./scripts/generate-agency-data.ts",
    "data:refresh:politicians": "tsx ./scripts/generate-politician-scorecards.ts",
    "data:import-csvs": "tsx ./scripts/import-csv-datasets.ts"
  },
  "keywords": [
    "data",
    "oecd",
    "world-bank",
    "census",
    "who",
    "economics",
    "health-data"
  ],
  "author": "Mike P. Sinn <m@thinkbynumbers.org>",
  "license": "MIT",
  "dependencies": {
    "@optimitron/optimizer": "workspace:*",
    "dotenv": "^17.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.32",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
