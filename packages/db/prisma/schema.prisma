/// Metadata about an external data source / integration (e.g. Fitbit, Apple Health, Oura).
/// Used to track which integrations are available and their connection status per user.
/// legacy API reference: https://github.com/mikepsinn/curedao-api/blob/main/app/Models/Connector.php
/// legacy API connectors: https://github.com/mikepsinn/curedao-api/blob/main/app/DataSources/Connectors/
model IntegrationProvider {
  /// Unique identifier for this integration provider
  id String @id @default(cuid())

  /// Machine-readable key (e.g. "fitbit", "apple-health", "oura", "strava")
  key String @unique

  /// Human-readable display name (e.g. "Fitbit", "Apple Health")
  displayName String

  /// Description of what data this integration provides
  description String?

  /// URL of the provider's logo / icon
  logoUrl String?

  /// Base URL for the provider's API (e.g. "https://api.fitbit.com")
  apiBaseUrl String?

  /// OAuth2 authorization URL (if applicable)
  authorizationUrl String?

  /// OAuth2 token URL (if applicable)
  tokenUrl String?

  /// Comma-separated list of OAuth2 scopes required
  scopes String?

  /// Whether this integration is currently enabled in the platform
  enabled Boolean @default(true)

  /// Whether this integration supports real-time data push (webhook)
  supportsWebhook Boolean @default(false)

  /// Whether this integration supports periodic polling for new data
  supportsPolling Boolean @default(true)

  /// Default polling interval in seconds (e.g. 3600 = hourly)
  defaultPollIntervalSeconds Int @default(3600)

  /// Comma-separated list of variable category names this provider typically supplies
  dataCategories String?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  connections IntegrationConnection[]

  @@index([enabled])
}

/// A user's connection to an integration provider (e.g., "User #42 connected to Fitbit")
/// legacy API reference: https://github.com/mikepsinn/curedao-api/blob/main/app/Models/Connection.php
model IntegrationConnection {
  /// Unique identifier for this connection
  id String @id @default(cuid())

  /// ID of the user who connected this integration
  userId String

  /// The integration provider
  integrationProviderId String

  /// Relation to the IntegrationProvider
  integrationProvider IntegrationProvider @relation(fields: [integrationProviderId], references: [id])

  /// Whether this connection is currently active and syncing
  enabled Boolean @default(true)

  /// Encrypted OAuth2 access token (if applicable)
  accessToken String?

  /// Encrypted OAuth2 refresh token (if applicable)
  refreshToken String?

  /// When the access token expires
  tokenExpiresAt DateTime?

  /// When data was last successfully synced from this connection
  lastSyncAt DateTime?

  /// When the next sync is scheduled
  nextSyncAt DateTime?

  /// Total number of measurements imported via this connection
  totalMeasurementsImported Int @default(0)

  /// Human-readable error message from the last failed sync (null if last sync succeeded)
  lastSyncError String?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  syncLogs     IntegrationSyncLog[]
  measurements Measurement[]

  @@unique([userId, integrationProviderId])
  @@index([userId])
  @@index([integrationProviderId])
  @@index([enabled])
}

/// Log of each sync attempt for an integration connection
/// legacy API reference: https://github.com/mikepsinn/curedao-api/blob/main/app/Models/ConnectorImport.php
model IntegrationSyncLog {
  /// Unique identifier for this sync log entry
  id String @id @default(cuid())

  /// The connection that was synced
  integrationConnectionId String

  /// Relation to the IntegrationConnection
  integrationConnection IntegrationConnection @relation(fields: [integrationConnectionId], references: [id])

  /// When this sync started
  startedAt DateTime @default(now())

  /// When this sync completed (null if still running or failed before completion)
  completedAt DateTime?

  /// Whether this sync was successful
  success Boolean @default(false)

  /// Number of new measurements imported in this sync
  newMeasurements Int @default(0)

  /// Number of existing measurements updated in this sync
  updatedMeasurements Int @default(0)

  /// Error message if the sync failed
  errorMessage String?

  /// When this record was created
  createdAt DateTime @default(now())

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  @@index([integrationConnectionId])
  @@index([startedAt])
}

// ============================================================================
// LAYER 2 — Domain-Specific Governance
// ============================================================================

/// A jurisdiction (city, county, state, country) — the tenant for governance data
model Jurisdiction {
  /// Unique identifier for this jurisdiction
  id String @id @default(cuid())

  /// Human-readable name (e.g. "California", "United States")
  name String

  /// Level of government
  type JurisdictionType

  /// Parent jurisdiction ID for hierarchy (e.g. city → county → state → country)
  parentJurisdictionId String?

  /// Relation to the parent Jurisdiction
  parent Jurisdiction? @relation("JurisdictionHierarchy", fields: [parentJurisdictionId], references: [id])

  /// Child jurisdictions in the hierarchy
  children Jurisdiction[] @relation("JurisdictionHierarchy")

  /// ISO codes, FIPS codes, etc. (e.g. "US", "US-CA", "US-CA-037")
  code String? @unique

  /// Currency code used in this jurisdiction (e.g. "USD", "EUR")
  currency String @default("USD")

  /// Estimated population of this jurisdiction
  population Int?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  items           Item[]
  participants    Participant[]
  politicians     Politician[]
  aggregationRuns AggregationRun[]
  referendums     Referendum[]

  @@index([type])
  @@index([parentJurisdictionId])
}

/// A priority/wish/budget item that can be compared in pairwise evaluations
model Item {
  /// Unique identifier for this item
  id String @id @default(cuid())

  /// Jurisdiction this item belongs to
  jurisdictionId String

  /// Relation to the Jurisdiction
  jurisdiction Jurisdiction @relation(fields: [jurisdictionId], references: [id])

  /// Human-readable name of the item (e.g. "National Defense", "Medicare")
  name String

  /// Longer explanation of what this item covers
  description String?

  /// Budget category: "Mandatory" | "Discretionary" | "Other" or custom
  category String?

  /// Current actual budget allocation in USD (for preference gap analysis)
  currentAllocationUsd Float?

  /// Current actual budget allocation as a percentage of total (for preference gap analysis)
  currentAllocationPct Float?

  /// URL to supporting documentation or source data
  sourceUrl String?

  /// Whether this item is active for comparisons
  active Boolean @default(true)

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  comparisonsAsA          PairwiseComparison[]           @relation("itemA")
  comparisonsAsB          PairwiseComparison[]           @relation("itemB")
  weights                 PreferenceWeight[]
  wishAllocationsAsA      WishocraticAllocation[]        @relation("wishItemA")
  wishAllocationsAsB      WishocraticAllocation[]        @relation("wishItemB")
  categorySelections      WishocraticCategorySelection[]
  politicianVotes         PoliticianVote[]
  categoryAlignmentScores CategoryAlignmentScore[]
  publicGoodsRecipients   PublicGoodsRecipient[]         @relation("publicGoodsItem")

  @@unique([jurisdictionId, name])
  @@index([jurisdictionId])
  @@index([category])
  @@index([active])
}

/// A participant who makes pairwise comparisons (anonymous by design)
model Participant {
  /// Unique identifier for this participant
  id String @id @default(cuid())

  /// Jurisdiction this participant is associated with
  jurisdictionId String

  /// Relation to the Jurisdiction
  jurisdiction Jurisdiction @relation(fields: [jurisdictionId], references: [id])

  /// Anonymous external ID (no PII stored)
  externalId String? @unique

  /// Optional age range for demographic analysis (e.g. "25-34")
  ageRange String?

  /// Optional region for geographic analysis (e.g. "US-CA")
  region String?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  comparisons PairwiseComparison[]

  @@index([jurisdictionId])
  @@index([region])
}

/// Referral/signup record for tracking who brought in a user
model Referral {
  /// Unique identifier for this referral
  id String @id @default(cuid())

  /// Whether the user opted into the referral/signup flow
  answer ReferralAnswer

  /// The user who signed up (one referral per user)
  userId String? @unique

  /// The user whose referral link led to this signup
  referredByUserId String?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  referrer User? @relation("UserReferrals", fields: [referredByUserId], references: [id])
  user     User? @relation("UserReferral", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([referredByUserId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("Vote")
}

/// Saved pairwise allocations for authenticated Wishocracy users
model WishocraticAllocation {
  /// Unique identifier for this allocation
  id String @id @default(cuid())

  /// The user who made this pairwise allocation
  userId String

  /// First item in the normalized pair (FK to Item — budget category)
  itemAId String

  /// Second item in the normalized pair (FK to Item — budget category)
  itemBId String

  /// Allocation to item A (0-100, represents share of hypothetical $100)
  allocationA Int

  /// Allocation to item B (0-100, represents share of hypothetical $100)
  allocationB Int

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  user  User @relation("UserWishocraticAllocations", fields: [userId], references: [id], onDelete: Cascade)
  itemA Item @relation("wishItemA", fields: [itemAId], references: [id])
  itemB Item @relation("wishItemB", fields: [itemBId], references: [id])

  @@unique([userId, itemAId, itemBId])
  @@index([userId])
  @@index([itemAId])
  @@index([itemBId])
  @@index([createdAt])
  @@index([deletedAt])
}

/// Saved category-inclusion choices for authenticated Wishocracy users
model WishocraticCategorySelection {
  /// Unique identifier for this category selection
  id String @id @default(cuid())

  /// The user who made this choice
  userId String

  /// Budget category item (FK to Item)
  itemId String

  /// Whether the category is included in the user's run
  selected Boolean

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  user User @relation("UserWishocraticCategorySelections", fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id])

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
  @@index([selected])
  @@index([createdAt])
  @@index([deletedAt])
}

/// A single pairwise comparison: "Given $100, how would you split it between A and B?"
model PairwiseComparison {
  /// Unique identifier for this comparison
  id String @id @default(cuid())

  /// The participant who made this comparison
  participantId String

  /// Relation to the Participant
  participant Participant @relation(fields: [participantId], references: [id])

  /// First item in the comparison pair
  itemAId String

  /// Relation to the first Item
  itemA Item @relation("itemA", fields: [itemAId], references: [id])

  /// Second item in the comparison pair
  itemBId String

  /// Relation to the second Item
  itemB Item @relation("itemB", fields: [itemBId], references: [id])

  /// Allocation to item A (0-100). Item B gets (100 - allocationA).
  allocationA Int

  /// Response time in milliseconds (engagement quality signal)
  responseTimeMs Int?

  /// Session ID to group comparisons from the same sitting
  sessionId String?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  @@unique([participantId, itemAId, itemBId])
  @@index([itemAId, itemBId])
  @@index([participantId])
  @@index([sessionId])
}

/// Aggregated preference weights (output of eigenvector calculation)
model PreferenceWeight {
  /// Unique identifier for this preference weight
  id String @id @default(cuid())

  /// Which calculation run produced this weight
  aggregationRunId String

  /// Relation to the AggregationRun
  aggregationRun AggregationRun @relation(fields: [aggregationRunId], references: [id])

  /// The item this weight applies to
  itemId String

  /// Relation to the Item
  item Item @relation(fields: [itemId], references: [id])

  /// Normalized weight (0-1, all weights in a run sum to 1)
  weight Float

  /// Rank of this item within the run (1 = highest priority)
  rank Int

  /// Lower bound of the confidence interval for this weight
  ciLow Float?

  /// Upper bound of the confidence interval for this weight
  ciHigh Float?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  @@unique([aggregationRunId, itemId])
  @@index([aggregationRunId])
}

/// Record of each aggregation calculation (eigenvector computation run)
model AggregationRun {
  /// Unique identifier for this aggregation run
  id String @id @default(cuid())

  /// Jurisdiction this run was computed for
  jurisdictionId String

  /// Relation to the Jurisdiction
  jurisdiction Jurisdiction @relation(fields: [jurisdictionId], references: [id])

  /// Total comparisons included in this run
  comparisonCount Int

  /// Total unique participants included in this run
  participantCount Int

  /// AHP consistency ratio (< 0.1 = good)
  consistencyRatio Float?

  /// Filter: which categories were included (null = all)
  categoryFilter String?

  /// Filter: which region was included (null = all)
  regionFilter String?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  weights         PreferenceWeight[]
  alignmentScores AlignmentScore[]

  @@index([jurisdictionId])
}

/// Politician/legislator/official voting records for alignment scoring
model Politician {
  /// Unique identifier for this politician
  id String @id @default(cuid())

  /// Jurisdiction this politician represents
  jurisdictionId String

  /// Relation to the Jurisdiction
  jurisdiction Jurisdiction @relation(fields: [jurisdictionId], references: [id])

  /// Full name of the politician
  name String

  /// Political party affiliation
  party String?

  /// Title: "Senator", "Mayor", "Council Member", etc.
  title String?

  /// State, ward, district — varies by jurisdiction
  district String?

  /// Legislative chamber: "house" | "senate" | "council" | null
  chamber String?

  /// External identifier: bioguide ID, local govt ID, etc.
  externalId String?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  votes      PoliticianVote[]
  alignments AlignmentScore[]

  @@unique([jurisdictionId, externalId])
  @@index([jurisdictionId])
  @@index([party])
}

/// A politician's vote or position on a budget item
model PoliticianVote {
  /// Unique identifier for this vote record
  id String @id @default(cuid())

  /// The politician who cast this vote
  politicianId String

  /// Relation to the Politician
  politician Politician @relation(fields: [politicianId], references: [id])

  /// Budget item this vote applies to (FK to Item)
  itemId String

  /// Relation to the Item
  item Item @relation(fields: [itemId], references: [id])

  /// Their allocated/voted percentage
  allocationPct Float

  /// Source bill or vote reference identifier
  billId String?

  /// When this vote was cast
  votedAt DateTime?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  @@unique([politicianId, itemId])
  @@index([politicianId])
  @@index([itemId])
}

/// Calculated alignment between citizen preferences and politician votes
model AlignmentScore {
  /// Unique identifier for this alignment score
  id String @id @default(cuid())

  /// The politician being scored
  politicianId String

  /// Relation to the Politician
  politician Politician @relation(fields: [politicianId], references: [id])

  /// Which aggregation run's weights were used to compute this score
  aggregationRunId String

  /// Relation to the AggregationRun
  aggregationRun AggregationRun @relation(fields: [aggregationRunId], references: [id])

  /// Overall alignment score (0-100%)
  score Float

  /// Number of votes compared in this calculation
  votesCompared Int

  /// When this score was published to the public API / Hypercerts
  publishedAt DateTime?

  /// On-chain reference (Hypercert CID or Merkle leaf hash)
  onChainRef String?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  categoryScores CategoryAlignmentScore[]

  @@unique([politicianId, aggregationRunId])
  @@index([score])
}

/// Per-category alignment breakdown for a politician in an aggregation run
model CategoryAlignmentScore {
  /// Unique identifier
  id String @id @default(cuid())

  /// Parent alignment score
  alignmentScoreId String

  /// Relation to the AlignmentScore
  alignmentScore AlignmentScore @relation(fields: [alignmentScoreId], references: [id], onDelete: Cascade)

  /// Budget category item (FK to Item)
  itemId String

  /// Relation to the Item
  item Item @relation(fields: [itemId], references: [id])

  /// Alignment score for this category (0-100%)
  score Float

  @@unique([alignmentScoreId, itemId])
  @@index([alignmentScoreId])
  @@index([itemId])
}

// ============================================================================
// CIVIC ENGAGEMENT
// ============================================================================

/// Position a citizen takes on a bill
enum VotePosition {
  YES
  NO
  ABSTAIN
}

/// A citizen's vote on a specific legislative bill, with optional CBA snapshot
model CitizenBillVote {
  /// Unique identifier
  id String @id @default(cuid())

  /// The user who cast this vote
  userId String

  /// Bill identifier e.g. "119-hr-1234"
  billId String

  /// Human-readable bill title at time of vote
  billTitle String

  /// The citizen's position
  position VotePosition

  /// Optional reasoning / notes
  reasoning String?

  /// Jurisdiction scope (optional)
  jurisdictionId String?

  /// Unique shareable identifier for public vote page
  shareIdentifier String @unique @default(cuid())

  /// JSON snapshot of cost-benefit analysis at time of vote
  cbaSnapshot String?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Relation to the user
  user User @relation("UserCitizenBillVotes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, billId])
  @@index([userId])
  @@index([billId])
  @@index([jurisdictionId])
  @@index([shareIdentifier])
}

/// Web push notification subscription for PWA push
model WebPushSubscription {
  /// Unique identifier
  id String @id @default(cuid())

  /// The user who subscribed
  userId String

  /// Push endpoint URL (unique per browser)
  endpoint String @unique

  /// P-256 Diffie-Hellman public key (base64)
  p256dh String

  /// Authentication secret (base64)
  auth String

  /// Browser user agent for debugging
  userAgent String?

  /// When subscription was created
  createdAt DateTime @default(now())

  /// Last time a notification was sent to this subscription
  lastSentAt DateTime?

  /// Whether subscription has expired (410 Gone response)
  expired Boolean @default(false)

  // -- Relations --
  user User @relation("UserWebPushSubscriptions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// User preferences for push notification timing
model NotificationPreference {
  /// Unique identifier
  id String @id @default(cuid())

  /// The user this preference belongs to
  userId String @unique

  /// Whether push notifications are enabled
  pushEnabled Boolean @default(true)

  /// How often to send reminders (minutes)
  reminderFrequencyMinutes Int @default(1440)

  /// Earliest time to send (HH:MM format)
  reminderStartTime String @default("09:00")

  /// Latest time to send (HH:MM format)
  quietHoursStart String @default("21:00")

  /// When the last push was sent
  lastPushSentAt DateTime?

  /// When the user last completed a check-in
  lastCheckInAt DateTime?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  user User @relation("UserNotificationPreference", fields: [userId], references: [id], onDelete: Cascade)
}

/// Encrypted pairwise allocations for Wishocracy (replaces plaintext per-comparison rows)
model WishocraticEncryptedAllocation {
  /// Unique identifier
  id String @id @default(cuid())

  /// The user who made these allocations
  userId String @unique

  /// AES-GCM encrypted JSON blob containing all pairwise allocations
  ciphertext String

  /// Initialization vector for AES-GCM (base64)
  iv String

  /// Encryption algorithm identifier
  algorithm String @default("AES-GCM-256")

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  user User @relation("UserEncryptedAllocations", fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================================
// LAYER 3 — Referendums & Verified Votes
// ============================================================================

enum ReferendumStatus {
  DRAFT
  ACTIVE
  CLOSED
}

/// A public referendum that users can vote on (e.g., "Should we adopt the 1% Treaty?")
model Referendum {
  /// Unique identifier
  id String @id @default(cuid())

  /// Human-readable title
  title String

  /// URL-safe slug for routing
  slug String @unique

  /// Rich description or framing text
  description String?

  /// User who created this referendum (optional for system-created ones)
  createdByUserId String?

  /// Optional jurisdiction scope
  jurisdictionId String?

  /// Whether this referendum is accepting votes
  status ReferendumStatus @default(ACTIVE)

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp
  deletedAt DateTime?

  // -- Relations --
  createdBy    User?            @relation("UserCreatedReferendums", fields: [createdByUserId], references: [id])
  jurisdiction Jurisdiction?    @relation(fields: [jurisdictionId], references: [id])
  votes        ReferendumVote[]

  @@index([slug])
  @@index([status])
  @@index([jurisdictionId])
}

/// A user's vote on a specific referendum
model ReferendumVote {
  /// Unique identifier
  id String @id @default(cuid())

  /// The user who cast this vote
  userId String

  /// Which referendum this vote is for
  referendumId String

  /// The citizen's position
  answer VotePosition

  /// Who brought this voter in via referral link
  referredByUserId String?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp
  deletedAt DateTime?

  // -- Relations --
  user       User       @relation("UserReferendumVotes", fields: [userId], references: [id], onDelete: Cascade)
  referendum Referendum @relation(fields: [referendumId], references: [id])
  referrer   User?      @relation("UserReferendumReferrals", fields: [referredByUserId], references: [id])

  @@unique([userId, referendumId])
  @@index([referendumId])
  @@index([referredByUserId])
}

// ============================================================================
// WISHOCRATIC TREASURY
// ============================================================================

/// A registered public goods recipient for a budget category.
/// Maps budget categories to on-chain wallet addresses that receive $WISH.
model PublicGoodsRecipient {
  /// Unique identifier
  id String @id @default(cuid())

  /// Budget category item (FK to Item — e.g., "UNIVERSAL_BASIC_INCOME")
  itemId String @unique

  /// Relation to the Item
  item Item @relation("publicGoodsItem", fields: [itemId], references: [id])

  /// Human-readable name
  name String

  /// On-chain wallet address (receives $WISH from WishocraticTreasury)
  walletAddress String

  /// Whether this recipient is currently active
  active Boolean @default(true)

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?
}

/// A record of a wishocratic distribution event on-chain.
model WishocraticDistribution {
  /// Unique identifier
  id String @id @default(cuid())

  /// Total $WISH distributed (bigint as string for precision)
  totalAmount String

  /// Number of recipients in this distribution
  recipientCount Int

  /// Hash of the allocation weights used (for auditability)
  weightsHash String

  /// On-chain transaction hash
  txHash String?

  /// When this distribution occurred
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  @@index([weightsHash])
}
