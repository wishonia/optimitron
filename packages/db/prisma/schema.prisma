// ============================================================================
// Optimitron Database Schema
// ============================================================================
//
// Two-layer architecture:
//
// LAYER 1 — Universal Measurement System (domain-agnostic)
//   GlobalVariable, VariableCategory, Unit, Subject, NOf1Variable, Measurement,
//   TrackingReminder, TrackingReminderNotification,
//   NOf1VariableRelationship, AggregateVariableRelationship,
//   IntegrationProvider
//   These models form a general-purpose quantified-self / data collection
//   platform. Any variable (health, economic, environmental, policy outcome)
//   can be tracked, aggregated, and analyzed for causal relationships.
//   Inspired by the legacy API open-source API. This is the Optimitron schema.
//
// LAYER 2 — Domain-Specific Governance
//   Jurisdiction, WishocraticItem, PreferenceWeight,
//   AggregationRun, Politician, PoliticianVote, AlignmentScore
//   These models implement the governance preference-elicitation system:
//   pairwise budget comparisons, eigenvector aggregation, and politician
//   alignment scoring. They are scoped to jurisdictions (multi-tenant).
//
// The two layers can interoperate: governance WishocraticItems can reference
// GlobalVariables as outcome metrics, and NOf1VariableRelationship /
// AggregateVariableRelationship can link policy variables to health/economic outcomes.
// ============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Zod schemas are manually maintained in ../src/zod/index.ts
// (zod-prisma-types generator was too slow on WSL2; may re-enable later)
// generator zod {
//   provider         = "zod-prisma-types"
//   output           = "../src/zod"
//   createInputTypes = false
//   addIncludeType   = false
//   addSelectType    = false
// }

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

/// How to aggregate multiple measurements within a time window
enum CombinationOperation {
  SUM
  MEAN
}

/// How to handle missing data points in a time series
enum FillingType {
  /// Treat missing as zero (e.g., "no dose taken" = 0 mg)
  ZERO
  /// Leave gaps (don't interpolate or assume)
  NONE
  /// Linearly interpolate between nearest values
  INTERPOLATION
  /// Use a specific constant value (set fillingValue on the variable)
  VALUE
}

/// Whether higher values are better or worse
enum Valence {
  /// Higher is better (e.g., mood, energy)
  POSITIVE
  /// Lower is better (e.g., pain, anxiety)
  NEGATIVE
  /// No inherent direction (e.g., heart rate)
  NEUTRAL
}

/// Measurement scale type (determines valid mathematical operations)
enum MeasurementScale {
  /// Categories with no order (e.g., blood type)
  NOMINAL
  /// Ordered categories (e.g., 1-5 rating)
  ORDINAL
  /// Equal intervals, arbitrary zero (e.g., temperature in °F)
  INTERVAL
  /// Equal intervals, true zero (e.g., weight in kg, duration in seconds)
  RATIO
}

/// Coding system used for unit identifiers
enum UnitCodeSystem {
  /// Unified Code for Units of Measure
  UCUM
}

/// Processing/analysis status for variables and relationships
enum AnalysisStatus {
  /// Waiting to be analyzed
  WAITING
  /// Analysis currently running
  ANALYZING
  /// Analysis complete
  DONE
  /// Analysis failed
  ERROR
}

/// Magnitude of a predictor-outcome relationship
enum StrengthLevel {
  VERY_STRONG
  STRONG
  MODERATE
  WEAK
  VERY_WEAK
}

/// Confidence that an observed relationship will persist with more data
enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
}

/// Direction of a predictor-outcome relationship
enum RelationshipDirection {
  POSITIVE
  NEGATIVE
  NONE
}

/// Letter grade summarizing overall evidence quality
enum EvidenceGrade {
  A
  B
  C
  D
  F
}

/// Status of a tracking reminder notification
enum NotificationStatus {
  PENDING
  SENT
  TRACKED
  SKIPPED
  SNOOZED
}

/// Level of government for a jurisdiction
enum JurisdictionType {
  CITY
  COUNTY
  STATE
  COUNTRY
}

/// Classification of an analysis subject
enum SubjectType {
  /// A single person/account
  USER
  /// A jurisdictional entity (country/state/city)
  JURISDICTION
  /// A grouped cohort (e.g., age band, treatment arm)
  COHORT
  /// An organization or institution
  ORGANIZATION
}

/// Referral/signup answer
enum ReferralAnswer {
  YES
  NO
}

/// External proof-of-personhood provider
enum PersonhoodProvider {
  WORLD_ID
  HUMAN_PASSPORT
}

/// Status of a proof-of-personhood verification
enum PersonhoodVerificationStatus {
  VERIFIED
  REVOKED
}

/// Type of activity event for the audit log
enum ActivityType {
  VOTED_REFERENDUM
  SUBMITTED_COMPARISON
  DEPOSITED_PRIZE
  RECRUITED_VOTER
  VERIFIED_PERSONHOOD
  TRACKED_MEASUREMENT
  UPDATED_PROFILE
  EARNED_BADGE
  CREATED_SURVEY
  COMPLETED_SURVEY
  JOINED_ORGANIZATION
}

/// Type of in-app notification
enum NotificationType {
  REFERRAL_SIGNUP
  REFERENDUM_MILESTONE
  ALIGNMENT_SCORE_PUBLISHED
  DEPOSIT_CONFIRMED
  BADGE_EARNED
  SURVEY_INVITE
  DAILY_CHECKIN_REMINDER
  ORGANIZATION_INVITE
  SYSTEM_ANNOUNCEMENT
}

/// Delivery channel for notifications
enum NotificationChannel {
  EMAIL
  IN_APP
  SMS
  PUSH
}

/// Type of organization
enum OrgType {
  UNIVERSITY
  RESEARCH_CENTER
  NONPROFIT
  DAO
  GOVERNMENT_AGENCY
  HOSPITAL
  BIOTECH
  ADVOCACY
}

/// Approval status of an organization
enum OrgStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Social/identity platform for linked accounts
enum SocialPlatform {
  TWITTER
  GITHUB
  ETHEREUM
  BASE
  DISCORD
  TELEGRAM
}

/// Achievement badge type
enum BadgeType {
  FIRST_COMPARISON
  HUNDRED_COMPARISONS
  FIRST_RECRUIT
  TEN_RECRUITS
  VERIFIED_HUMAN
  EARLY_ADOPTER
  DEPOSITOR
}

/// Reason a wish was granted — maps to a specific user action
enum WishReason {
  WORLD_ID_VERIFICATION
  KYC_COMPLETION
  CENSUS_SNAPSHOT
  DAILY_CHECKIN
  WISHOCRATIC_ALLOCATION
  REFERENDUM_VOTE
  ALIGNMENT_CHECK
  REFERRAL
  PRIZE_DEPOSIT
  SHARE_REPORT
}

/// Type of survey question
enum QuestionType {
  MULTIPLE_CHOICE
  FREE_TEXT
  RATING
  BOOLEAN
  NUMERIC
}

/// Delivery status for email log
enum EmailLogStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  BOUNCED
  FAILED
}

// ============================================================================
// AUTH / ACCOUNT LAYER
// ============================================================================

/// Application user account used for Optimitron and Wishocracy sign-in
model User {
  /// Unique identifier for this user
  id String @id @default(cuid())

  /// Unique email address used for authentication
  email String @unique

  /// Optional display name
  name String?

  /// Optional public username used in referral links
  username String? @unique

  /// Optional avatar URL
  image String?

  /// Password hash for credentials auth
  password String?

  /// Human-shareable referral code
  referralCode String @unique @default(cuid())

  /// Set once the user has completed email verification
  emailVerified DateTime?

  /// Whether the user wants updates about progress
  newsletterSubscribed Boolean @default(true)

  /// Preferred IANA time zone for reminders and daily check-ins
  timeZone String?

  /// Country or country code for decentralized census grouping
  countryCode String?

  /// State, province, or other first-level region
  regionCode String?

  /// City or locality
  city String?

  /// Postal or ZIP code
  postalCode String?

  /// Latest saved latitude for profile/home location
  latitude Float?

  /// Latest saved longitude for profile/home location
  longitude Float?

  /// Self-reported annual household income in USD
  annualHouseholdIncomeUsd Float?

  /// Self-reported annual personal income in USD (primary scoreboard metric)
  annualPersonalIncomeUsd Float?

  /// Number of people supported by the household income
  householdSize Int?

  /// Self-reported birth year
  birthYear Int?

  /// Highest completed education level
  educationLevel String?

  /// Employment status for census segmentation
  employmentStatus String?

  /// Self-described gender identity
  genderIdentity String?

  /// Free-form census notes for additional demographic context
  censusNotes String?

  // ── Demographics ──────────────────────────────────────────
  /// Biological sex for actuarial life-expectancy tables (separate from genderIdentity)
  biologicalSex      String?
  /// Self-described ethnicity or race (freeform — categories vary by country)
  ethnicityOrRace    String?
  /// Marital or partnership status
  maritalStatus      String?
  /// Number of dependents (children or others financially supported)
  numberOfDependents Int?
  /// Primary spoken language (ISO 639-1 code or freeform)
  primaryLanguage    String?

  // ── Health / HALE ─────────────────────────────────────────
  /// Type of health insurance coverage
  healthInsuranceType   String?
  /// Number of chronic conditions (0, 1, 2, 3 = "3 or more")
  chronicConditionCount Int?
  /// Disability status
  disabilityStatus      String?
  /// Smoking status (never, former, current)
  smokingStatus         String?
  /// Alcohol consumption frequency
  alcoholFrequency      String?
  /// Height in centimeters (for BMI calculation with periodic weight check-ins)
  heightCm              Float?

  // ── Economic (after-tax income derivation) ────────────────
  /// Self-reported annual taxes paid in USD
  annualTaxesPaidUsd    Float?
  /// Monthly housing cost in USD (rent or mortgage payment)
  monthlyHousingCostUsd Float?
  /// Housing status (own, rent, other, homeless)
  housingStatus         String?
  /// Typical hours worked per week
  hoursWorkedPerWeek    Int?
  /// Industry or employment sector (freeform)
  industryOrSector      String?

  // ── Access ────────────────────────────────────────────────
  /// Citizenship or immigration status
  citizenshipStatus  String?
  /// Type of internet access
  internetAccessType String?

  /// When the census/location snapshot was last updated
  censusUpdatedAt DateTime?

  /// Short bio for public profile
  bio String?

  /// One-line headline (e.g. "Data scientist at X")
  headline String?

  /// Cover/banner image URL
  coverImage String?

  /// Personal website URL
  website String?

  /// Whether this profile is publicly visible
  isPublic Boolean @default(false)

  /// Whether this user has admin privileges
  isAdmin Boolean @default(false)

  /// Phone number for SMS notifications
  phoneNumber String?

  /// Number of referral-sequence emails already sent to this user
  referralEmailSequenceStep Int @default(0)

  /// Timestamp of the most recent referral-sequence email
  referralEmailSequenceLastSentAt DateTime?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  accounts                  Account[]
  personhoodVerifications   PersonhoodVerification[]
  referrals                 Referral[]                      @relation("UserReferrals")
  sessions                  Session[]
  referral                  Referral?                       @relation("UserReferral")
  wishocraticAllocations    WishocraticAllocation[]         @relation("UserWishocraticAllocations")
  wishocraticItemInclusions WishocraticItemInclusion[]      @relation("UserWishocraticItemInclusions")
  citizenBillVotes          CitizenBillVote[]               @relation("UserCitizenBillVotes")
  webPushSubscriptions      WebPushSubscription[]           @relation("UserWebPushSubscriptions")
  userPreference            UserPreference?                 @relation("UserPreference")
  notificationPreferences   NotificationPreference[]        @relation("UserNotificationPreferences")
  notifications             Notification[]                  @relation("UserNotifications")
  encryptedAllocations      WishocraticEncryptedAllocation? @relation("UserEncryptedAllocations")
  createdReferendums        Referendum[]                    @relation("UserCreatedReferendums")
  referendumVotes           ReferendumVote[]                @relation("UserReferendumVotes")
  referendumReferrals       ReferendumVote[]                @relation("UserReferendumReferrals")
  voteTokenMints            VoteTokenMint[]                 @relation("UserVoteTokenMints")
  activities                Activity[]                      @relation("UserActivities")
  createdOrganizations      Organization[]                  @relation("OrgCreator")
  organizationMemberships   OrganizationMember[]            @relation("UserOrgMemberships")
  badges                    Badge[]                         @relation("UserBadges")
  wishPoints                WishPoint[]                     @relation("UserWishPoints")
  socialAccounts            SocialAccount[]                 @relation("UserSocialAccounts")
  emailLogs                 EmailLog[]                      @relation("UserEmailLogs")
  surveyResponses           SurveyResponse[]                @relation("UserSurveyResponses")

  @@index([email])
  @@index([username])
  @@index([referralCode])
  @@index([countryCode, regionCode])
  @@index([annualHouseholdIncomeUsd])
  @@index([annualPersonalIncomeUsd])
  @@index([censusUpdatedAt])
  @@index([createdAt])
  @@index([referralEmailSequenceStep, referralEmailSequenceLastSentAt])
  @@index([isPublic])
  @@index([deletedAt])
}

/// OAuth, email, or credentials account attached to a user
model Account {
  /// Unique identifier for this account link
  id String @id @default(cuid())

  /// The user who owns this provider account
  userId String

  /// Provider type ("oauth", "email", "credentials")
  type String

  /// Provider identifier ("google", "email", "credentials")
  provider String

  /// Provider-specific account identifier
  providerAccountId String

  /// OAuth refresh token if supplied
  refresh_token String?

  /// OAuth access token if supplied
  access_token String?

  /// Absolute expiry time of the access token in seconds
  expires_at Int?

  /// OAuth token type if supplied
  token_type String?

  /// OAuth scopes if supplied
  scope String?

  /// OIDC ID token if supplied
  id_token String?

  /// Provider session state if supplied
  session_state String?

  /// OAuth 1.0 token secret if supplied
  oauth_token_secret String?

  /// OAuth 1.0 access token if supplied
  oauth_token String?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([provider])
  @@index([deletedAt])
}

/// Active login session for database-backed NextAuth flows
model Session {
  /// Unique identifier for this session
  id String @id @default(cuid())

  /// Random session token stored in the session cookie
  sessionToken String @unique

  /// The user who owns this session
  userId String

  /// When this session expires
  expires DateTime

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
  @@index([deletedAt])
}

/// One-time magic-link verification token
model VerificationToken {
  /// Email address that requested the token
  identifier String

  /// Hashed or raw verification token depending on provider config
  token String @unique

  /// When the token expires
  expires DateTime

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  @@unique([identifier, token])
  @@index([expires])
  @@index([deletedAt])
}

/// Verified proof-of-personhood attached to a user account
model PersonhoodVerification {
  /// Unique identifier for this verification record
  id String @id @default(cuid())

  /// The user who completed this verification
  userId String

  /// Which provider issued this verification
  provider PersonhoodProvider

  /// Current status of this verification
  status PersonhoodVerificationStatus @default(VERIFIED)

  /// Provider-scoped identifier used to enforce uniqueness
  externalId String

  /// Provider action or scoring context
  action String?

  /// Provider-specific level or credential type
  verificationLevel String?

  /// Optional signal hash or equivalent binding field
  signalHash String?

  /// Timestamp of the first successful verification
  verifiedAt DateTime @default(now())

  /// Timestamp of the most recent successful verification
  lastVerifiedAt DateTime @default(now())

  /// Optional expiration time for time-bounded verifications
  expiresAt DateTime?

  /// JSON-encoded provider metadata for future extensibility
  providerMetadata String?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@unique([userId, provider])
  @@index([userId, status])
  @@index([provider, status])
  @@index([verifiedAt])
  @@index([deletedAt])
}

// ============================================================================
// LAYER 1 — Universal Measurement System
// ============================================================================

/// A unit of measurement (mg, IU, serving, $/day, 1-5 scale, %, etc.)
/// legacy API reference: https://github.com/mikepsinn/curedao-api/blob/main/app/Models/Unit.php
/// legacy API DDL: units table. Conversion logic: https://github.com/mikepsinn/curedao-api/blob/main/app/Slim/Model/QMUnit.php
/// Runtime unit conversion implemented in packages/data/src/unit-conversion.ts
model Unit {
  /// Unique identifier for this unit
  id String @id @default(cuid())

  /// Human-readable name (e.g. "Milligrams")
  name String @unique

  /// Short form shown in UI (e.g. "mg")
  abbreviatedName String @unique

  /// Unit coding system (currently UCUM-only)
  codeSystem UnitCodeSystem @default(UCUM)

  /// UCUM code (e.g. "mg", "kg", "mm[Hg]")
  ucumCode String @unique

  /// Grouping: Weight, Volume, Count, Rating, Currency, Percent, Duration, etc.
  unitCategoryId String

  /// Minimum allowed value for a single measurement in this unit
  minimumValue Float?

  /// Maximum allowed value for a single measurement in this unit
  maximumValue Float?

  /// How to handle missing data for this unit
  fillingType FillingType @default(NONE)

  /// Measurement scale type (determines valid mathematical operations)
  scale MeasurementScale @default(RATIO)

  /// JSON-encoded conversion steps to convert to the category's base unit.
  /// Each step is an operation (multiply, add, etc.) applied sequentially.
  conversionSteps String?

  /// If true, hide from simple UI — only show in advanced mode
  advanced Boolean @default(false)

  /// If true, show this unit in the manual tracking UI
  manualTracking Boolean @default(true)

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  globalVariables      GlobalVariable[]   @relation("GlobalVariableDefaultUnit")
  variableCategories   VariableCategory[] @relation("VariableCategoryDefaultUnit")
  nOf1Variables        NOf1Variable[]     @relation("NOf1VariableDefaultUnit")
  measurements         Measurement[]      @relation("MeasurementUnit")
  measurementsOriginal Measurement[]      @relation("MeasurementOriginalUnit")

  @@index([unitCategoryId])
}

/// A category of variables: Treatment, Symptom, Emotion, Food, Activity,
/// Sleep, Vital Sign, Lab Result, Environment, Economic, Policy, etc.
/// legacy API reference: https://github.com/mikepsinn/curedao-api/blob/main/app/Models/VariableCategory.php
/// legacy API hardcoded categories: https://github.com/mikepsinn/curedao-api/blob/main/app/VariableCategories/
/// Seed data with defaults implemented in packages/db/prisma/seed.ts (15+ categories)
model VariableCategory {
  /// Unique identifier for this variable category
  id String @id @default(cuid())

  /// Human-readable category name (e.g. "Treatment", "Symptom")
  name String @unique

  /// Longer explanation of what variables in this category represent
  description String?

  /// Default unit for variables in this category
  defaultUnitId String?

  /// Relation to the default Unit for this category
  defaultUnit Unit? @relation("VariableCategoryDefaultUnit", fields: [defaultUnitId], references: [id])

  /// How to aggregate multiple measurements within a time window
  combinationOperation CombinationOperation @default(SUM)

  /// Default onset delay for variables in this category (seconds)
  onsetDelay Int @default(0)

  /// Default duration of action for variables in this category (seconds)
  durationOfAction Int @default(86400)

  /// If true, variables in this category can only be predictors, never outcomes
  predictorOnly Boolean @default(false)

  /// If true, variables in this category are outcomes people want to optimize
  outcome Boolean?

  /// URL of the category's representative image / icon
  imageUrl String?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  globalVariables GlobalVariable[]

  @@index([name])
}

/// The canonical variable catalog — shared across all users.
/// Examples: "Ibuprofen 200mg", "Overall Mood", "Steps", "GDP per Capita"
/// legacy API reference: https://github.com/mikepsinn/curedao-api/blob/main/app/Models/Variable.php
/// legacy API analysis: https://github.com/mikepsinn/curedao-api/blob/main/app/Variables/QMCommonVariable.php
/// Global variable statistics implemented in packages/data/src/variable-statistics.ts (aggregateGlobalStatistics)
model GlobalVariable {
  /// Unique identifier for this global variable
  id String @id @default(cuid())

  /// Unique human-readable name (e.g. "Ibuprofen 200mg", "Overall Mood")
  name String @unique

  /// Longer explanation of what this variable measures
  description String?

  /// Category this variable belongs to (Treatment, Symptom, etc.)
  variableCategoryId String

  /// Relation to the VariableCategory
  variableCategory VariableCategory @relation(fields: [variableCategoryId], references: [id])

  /// Default unit for measurements of this variable
  defaultUnitId String

  /// Relation to the default Unit
  defaultUnit Unit @relation("GlobalVariableDefaultUnit", fields: [defaultUnitId], references: [id])

  /// How to aggregate within a time window: SUM (e.g. mg taken) or MEAN (e.g. mood rating)
  combinationOperation CombinationOperation @default(SUM)

  /// Seconds before this variable's effect begins after a measurement
  onsetDelay Int?

  /// Seconds the effect of a measurement lasts
  durationOfAction Int?

  /// How to handle missing data for this variable
  fillingType FillingType @default(NONE)

  /// Value to substitute for missing data when fillingType is INTERPOLATION
  fillingValue Float?

  /// If true, this variable can only be a predictor, never an outcome
  predictorOnly Boolean @default(false)

  /// If true, this variable is an outcome people want to optimize
  outcome Boolean?

  /// Minimum reasonable value for a single measurement of this variable
  minimumAllowedValue Float?

  /// Maximum reasonable value for a single measurement of this variable
  maximumAllowedValue Float?

  /// Total number of measurements across all users for this variable
  numberOfMeasurements Int @default(0)

  /// Timestamp of the most recent measurement for this variable (any user)
  latestMeasurementStartAt DateTime?

  /// Timestamp of the earliest measurement for this variable (any user)
  earliestMeasurementStartAt DateTime?

  /// Mean value across all measurements for this variable
  mean Float?

  /// Median value across all measurements for this variable
  median Float?

  /// Standard deviation of all measurements for this variable
  standardDeviation Float?

  /// Variance of all measurements for this variable
  variance Float?

  /// Kurtosis of the measurement distribution (measures tail heaviness)
  kurtosis Float?

  /// Skewness of the measurement distribution (measures asymmetry)
  skewness Float?

  /// Number of distinct values recorded across all users
  numberOfUniqueValues Int?

  /// Most frequently recorded value
  mostCommonValue Float?

  /// Second most frequently recorded value
  secondMostCommonValue Float?

  /// Lowest value ever recorded for this variable (any user)
  minimumRecordedValue Float?

  /// Highest value ever recorded for this variable (any user)
  maximumRecordedValue Float?

  /// Number of users who track this variable
  numberOfNOf1Variables Int @default(0)

  /// Processing status for statistical analysis
  status AnalysisStatus @default(WAITING)

  /// When analysis was last requested
  analysisRequestedAt DateTime?

  /// When the last statistical analysis began
  analysisStartedAt DateTime?

  /// When the last statistical analysis completed
  analysisEndedAt DateTime?

  /// URL of the variable's representative image / icon
  imageUrl String?

  /// URL to more information about this variable
  informationalUrl String?

  /// Comma-separated synonyms for search (e.g. "Advil,Motrin" for Ibuprofen)
  synonyms String?

  /// Is higher better? POSITIVE = higher is better, NEGATIVE = lower is better
  valence Valence @default(NEUTRAL)

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  nOf1Variables                     NOf1Variable[]
  measurements                      Measurement[]
  trackingReminders                 TrackingReminder[]
  nOf1RelationshipsAsPredictor      NOf1VariableRelationship[]      @relation("NOf1RelPredictorGlobal")
  nOf1RelationshipsAsOutcome        NOf1VariableRelationship[]      @relation("NOf1RelOutcomeGlobal")
  aggregateRelationshipsAsPredictor AggregateVariableRelationship[] @relation("AggregateRelPredictorGlobal")
  aggregateRelationshipsAsOutcome   AggregateVariableRelationship[] @relation("AggregateRelOutcomeGlobal")

  @@index([variableCategoryId])
  @@index([defaultUnitId])
  @@index([name])
}

/// Generic analysis subject for N-of-1 and aggregate pipelines.
/// Enables modeling users, jurisdictions, cohorts, and organizations
/// under one identity type without overloading measurement `Unit`.
model Subject {
  /// Unique identifier for this subject
  id String @id @default(cuid())

  /// Subject classification
  subjectType SubjectType @default(USER)

  /// External source identifier, if available
  externalId String? @unique

  /// Human-readable subject label
  displayName String?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  nOf1Variables             NOf1Variable[]
  nOf1VariableRelationships NOf1VariableRelationship[]

  @@index([subjectType])
}

/// Per-subject instance of a GlobalVariable with personal overrides and running stats.
/// Created automatically when a user first tracks a variable.
/// legacy API reference: https://github.com/mikepsinn/curedao-api/blob/main/app/Models/UserVariable.php
/// legacy API analysis: https://github.com/mikepsinn/curedao-api/blob/main/app/Variables/QMUserVariable.php
/// legacy API daily aggregation: QMUserVariable::getDailyMeasurementsWithTagsAndFillingInTimeRange()
/// Running statistics implemented in packages/data/src/variable-statistics.ts (calculateNOf1VariableStatistics)
/// Daily value aggregation implemented in packages/data/src/daily-aggregation.ts (aggregateToDaily)
model NOf1Variable {
  /// Unique identifier for this unit-variable instance
  id String @id @default(cuid())

  /// ID of the user who owns this variable instance
  userId String

  /// Optional generic subject owner ID (migration path from user-only ownership)
  subjectId String?

  /// Relation to Subject
  subject Subject? @relation(fields: [subjectId], references: [id])

  /// ID of the canonical GlobalVariable this is an instance of
  globalVariableId String

  /// Relation to the canonical GlobalVariable
  globalVariable GlobalVariable @relation(fields: [globalVariableId], references: [id])

  /// User's preferred unit (overrides global default)
  defaultUnitId String?

  /// Relation to the user's preferred Unit
  defaultUnit Unit? @relation("NOf1VariableDefaultUnit", fields: [defaultUnitId], references: [id])

  /// Personal override for onset delay (seconds)
  onsetDelay Int?

  /// Personal override for duration of action (seconds)
  durationOfAction Int?

  /// How to handle missing data for this user's variable
  fillingType FillingType @default(NONE)

  /// Personal override for the fill value when fillingType is "value"
  fillingValue Float?

  /// Personal minimum reasonable value for a single measurement
  minimumAllowedValue Float?

  /// Personal maximum reasonable value for a single measurement
  maximumAllowedValue Float?

  // -- Running statistics (updated on each new measurement) --

  /// Total number of measurements this unit has recorded for this variable
  numberOfMeasurements Int @default(0)

  /// Timestamp of this unit's most recent measurement for this variable
  latestMeasurementStartAt DateTime?

  /// Timestamp of this unit's earliest measurement for this variable
  earliestMeasurementStartAt DateTime?

  /// Arithmetic mean of this unit's measurements
  mean Float?

  /// Median of this unit's measurements
  median Float?

  /// Standard deviation of this unit's measurements
  standardDeviation Float?

  /// Variance of this unit's measurements
  variance Float?

  /// Kurtosis of this user's measurement distribution
  kurtosis Float?

  /// Skewness of this user's measurement distribution
  skewness Float?

  /// Lowest value this unit has ever recorded
  minimumRecordedValue Float?

  /// Highest value this unit has ever recorded
  maximumRecordedValue Float?

  /// Processing status: "WAITING" | "ANALYZING" | "DONE" | "ERROR"
  status AnalysisStatus @default(WAITING)

  /// When the last statistical analysis began for this unit-variable
  analysisStartedAt DateTime?

  /// When the last statistical analysis completed for this unit-variable
  analysisEndedAt DateTime?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  measurements      Measurement[]
  trackingReminders TrackingReminder[]

  @@unique([userId, globalVariableId])
  @@index([userId])
  @@index([subjectId])
  @@index([globalVariableId])
}

/// A single data point: who measured what, when, and how much.
/// The core of the entire measurement system.
/// legacy API reference: https://github.com/mikepsinn/curedao-api/blob/main/app/Models/Measurement.php
/// legacy API processing: https://github.com/mikepsinn/curedao-api/blob/main/app/Traits/ModelTraits/MeasurementTrait.php
/// Measurement validation implemented in packages/data/src/measurement-validation.ts (validateMeasurement)
model Measurement {
  /// Unique identifier for this measurement
  id String @id @default(cuid())

  /// ID of the user who recorded this measurement
  userId String

  /// Link to the unit's personal variable instance
  nOf1VariableId String

  /// Relation to the NOf1Variable
  nOf1Variable NOf1Variable @relation(fields: [nOf1VariableId], references: [id])

  /// Link to the canonical GlobalVariable being measured
  globalVariableId String

  /// Relation to the GlobalVariable
  globalVariable GlobalVariable @relation(fields: [globalVariableId], references: [id])

  /// When the measurement was taken / event started
  startTime DateTime

  /// Value converted to the variable's default unit
  value Float

  /// Unit of the converted value (should match variable's default unit)
  unitId String

  /// Relation to the converted value's Unit
  unit Unit @relation("MeasurementUnit", fields: [unitId], references: [id])

  /// Value as originally entered by the user (before conversion)
  originalValue Float

  /// Unit of the original value (before conversion)
  originalUnitId String

  /// Relation to the original Unit
  originalUnit Unit @relation("MeasurementOriginalUnit", fields: [originalUnitId], references: [id])

  /// Duration of the event in seconds (e.g. 1800 for 30 min exercise)
  duration Int?

  /// Free-text note from the user
  note String?

  /// Name of the app, device, or integration that provided this data (e.g. "Fitbit", "manual")
  sourceName String?

  /// Link to the integration connection that imported this measurement (null if manual entry)
  integrationConnectionId String?

  /// Relation to the IntegrationConnection
  integrationConnection IntegrationConnection? @relation(fields: [integrationConnectionId], references: [id])

  /// Latitude of the user's location at time of measurement
  latitude Float?

  /// Longitude of the user's location at time of measurement
  longitude Float?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  @@unique([userId, globalVariableId, startTime])
  @@index([userId])
  @@index([userId, startTime])
  @@index([globalVariableId])
  @@index([globalVariableId, startTime])
  @@index([nOf1VariableId])
  @@index([startTime])
  @@index([userId, globalVariableId, startTime])
}

/// A scheduled reminder to collect data for a variable.
/// E.g. "Remind me to rate my mood every day at 8:00 AM"
/// legacy API reference: https://github.com/mikepsinn/curedao-api/blob/main/app/Models/TrackingReminder.php
model TrackingReminder {
  /// Unique identifier for this tracking reminder
  id String @id @default(cuid())

  /// ID of the user who owns this reminder
  userId String

  /// Link to the unit's personal variable instance
  nOf1VariableId String

  /// Relation to the NOf1Variable
  nOf1Variable NOf1Variable @relation(fields: [nOf1VariableId], references: [id])

  /// Link to the canonical GlobalVariable being tracked
  globalVariableId String

  /// Relation to the GlobalVariable
  globalVariable GlobalVariable @relation(fields: [globalVariableId], references: [id])

  /// Pre-filled default value when tracking from this reminder
  defaultValue Float?

  /// Local time of day for the reminder (e.g. "08:00")
  reminderStartTime String

  /// End of quiet hours — no reminders after this time (e.g. "22:00")
  reminderEndTime String?

  /// Seconds between reminders (e.g. 86400 = daily, 3600 = hourly)
  reminderFrequency Int

  /// Whether this reminder is currently active
  active Boolean @default(true)

  /// Instructions shown to the user when the reminder fires
  instructions String?

  /// When the user last tracked this variable via any reminder
  lastTracked DateTime?

  /// Date (inclusive) from which this reminder should start firing
  startTrackingDate DateTime?

  /// Date (inclusive) after which this reminder should stop firing
  stopTrackingDate DateTime?

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  // -- Relations --
  notifications TrackingReminderNotification[]

  @@unique([userId, globalVariableId, reminderStartTime, reminderFrequency])
  @@index([userId])
  @@index([globalVariableId])
  @@index([nOf1VariableId])
  @@index([active])
}

/// A queued notification for a tracking reminder.
/// Each row represents a single pending or sent notification instance.
/// legacy API reference: https://github.com/mikepsinn/curedao-api/blob/main/app/Models/TrackingReminderNotification.php
model TrackingReminderNotification {
  /// Unique identifier for this notification
  id String @id @default(cuid())

  /// ID of the user this notification is for
  userId String

  /// The tracking reminder that generated this notification
  trackingReminderId String

  /// Relation to the parent TrackingReminder
  trackingReminder TrackingReminder @relation(fields: [trackingReminderId], references: [id])

  /// Scheduled time for this notification to be sent
  notifyAt DateTime

  /// When the notification was actually delivered (null if pending)
  notifiedAt DateTime?

  /// When the user responded to this notification (null if not yet responded)
  receivedAt DateTime?

  /// The value the user tracked in response (null if not yet tracked)
  trackedValue Float?

  /// Status of this notification: "pending" | "sent" | "tracked" | "skipped" | "snoozed"
  status NotificationStatus @default(PENDING)

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  @@index([userId, status])
  @@index([trackingReminderId])
  @@index([notifyAt])
}

/// Subject-level n-of-1 causal inference analysis between two variables.
/// Each row answers: "For THIS subject, how does variable A predict variable B?"
/// legacy API reference: https://github.com/mikepsinn/curedao-api/blob/main/app/Models/Correlation.php
/// legacy API analysis pipeline: https://github.com/mikepsinn/curedao-api/blob/main/app/Correlations/QMUserCorrelation.php
/// legacy API calculation properties: https://github.com/mikepsinn/curedao-api/blob/main/app/Properties/Correlation/
model NOf1VariableRelationship {
  /// Unique identifier for this subject-level relationship
  id String @id @default(cuid())

  /// The analyzed subject (user, jurisdiction, cohort, etc.)
  subjectId String

  /// Relation to the analyzed Subject
  subject Subject @relation(fields: [subjectId], references: [id])

  /// The predictor (input/cause) variable in this relationship
  predictorGlobalVariableId String

  /// Relation to the predictor GlobalVariable
  predictorGlobalVariable GlobalVariable @relation("NOf1RelPredictorGlobal", fields: [predictorGlobalVariableId], references: [id])

  /// The outcome (effect/result) variable in this relationship
  outcomeGlobalVariableId String

  /// Relation to the outcome GlobalVariable
  outcomeGlobalVariable GlobalVariable @relation("NOf1RelOutcomeGlobal", fields: [outcomeGlobalVariableId], references: [id])

  // -- Statistical fields --

  /// Pearson correlation with predictor preceding outcome (expected causal direction)
  forwardPearsonCorrelation Float

  /// Pearson correlation with outcome preceding predictor — if reverse > forward,
  /// the assumed causal direction may be wrong
  reversePearsonCorrelation Float

  /// Spearman rank correlation (assesses monotonic relationships, linear or not)
  forwardSpearmanCorrelation Float?

  /// Statistical significance (< 0.05 = significant)
  pValue Float?

  /// Student's t-value (function of correlation and sample size)
  tValue Float?

  /// Threshold t-value from lookup table that t must exceed for significance
  criticalTValue Float?

  /// Margin of error around the effect size
  confidenceInterval Float?

  /// A function of the effect size and sample size
  statisticalSignificance Float?

  /// Standard deviations from the mean — z > 2 means p < 0.05
  zScore Float?

  /// Number of predictor-outcome measurement pairs used in the analysis
  numberOfPairs Int

  /// Number of days of data included in the analysis
  numberOfDays Int?

  /// Strongest Pearson correlation found across all onset delay permutations
  strongestPearsonCorrelation Float?

  /// Optimal Pearson product (correlation × statistical significance)
  optimalPearsonProduct Float?

  // -- Temporal parameters --

  /// Time after predictor measurement before a perceivable outcome change is observed (seconds)
  onsetDelay Int

  /// Time over which the predictor produces a perceivable outcome change following onset (seconds)
  durationOfAction Int

  /// The onset delay (seconds) that produced the strongest Pearson correlation
  onsetDelayWithStrongestCorrelation Int?

  // -- Outcome / prediction fields --

  /// Predictor value that predicts an above-average outcome (in predictor's default unit)
  valuePredictingHighOutcome Float?

  /// Predictor value that predicts a below-average outcome (in predictor's default unit)
  valuePredictingLowOutcome Float?

  /// Percent change in outcome typically seen when predictor value is high
  predictsHighOutcomeChange Int?

  /// Percent change in outcome typically seen when predictor value is low
  predictsLowOutcomeChange Int?

  /// Average outcome value across all measurements
  averageOutcome Float?

  /// Average outcome value following an above-average predictor value
  averageOutcomeFollowingHighPredictor Float?

  /// Average outcome value following a below-average predictor value
  averageOutcomeFollowingLowPredictor Float?

  /// Average daily predictor value on days associated with high outcome
  averageDailyHighPredictor Float?

  /// Average daily predictor value on days associated with low outcome
  averageDailyLowPredictor Float?

  /// Standardized effect size (Cohen's d or similar)
  effectSize Float?

  // -- Baseline / treatment comparison --

  /// Average daily predictor value during non-treatment (baseline) periods
  predictorBaselineAveragePerDay Float?

  /// Average daily predictor value during treatment periods
  predictorTreatmentAveragePerDay Float?

  /// Average outcome value during baseline (no treatment) periods
  outcomeBaselineAverage Float?

  /// Standard deviation of outcome during baseline periods
  outcomeBaselineStandardDeviation Float?

  /// Average outcome value during follow-up (post-treatment) periods
  outcomeFollowUpAverage Float?

  /// Percent change in outcome from baseline to follow-up
  outcomeFollowUpPercentChangeFromBaseline Float?

  // -- Quality / meta fields --

  /// Magnitude of the predictor-outcome relationship
  strengthLevel StrengthLevel?

  /// Confidence that this relationship will persist with more data
  confidenceLevel ConfidenceLevel?

  /// Direction: "POSITIVE" | "NEGATIVE" | "NONE"
  relationship RelationshipDirection?

  /// Predictor Impact Score — composite importance metric
  predictorImpactScore Float?

  /// Letter grade summarizing evidence quality: A/B/C/D/F
  evidenceGrade EvidenceGrade?

  /// Number of times the predictor measurement value changed from the preceding value
  predictorChanges Int?

  /// Number of times the outcome measurement value changed from the preceding value
  outcomeChanges Int?

  /// True if the relationship is obvious, uncontrollable, or too low confidence to be actionable
  trivial Boolean?

  /// True if the outcome variable is something the user wants to optimize
  outcomeIsGoal Boolean?

  /// True if the predictor variable is directly controllable by the user
  predictorIsControllable Boolean?

  /// True if there is a plausible mechanism of action for this relationship
  plausiblyCausal Boolean?

  /// The predictor value associated with the best outcome
  optimalValue Float?

  /// When this analysis was last computed
  analyzedAt DateTime

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  @@unique([subjectId, predictorGlobalVariableId, outcomeGlobalVariableId])
  @@index([subjectId])
  @@index([predictorGlobalVariableId])
  @@index([outcomeGlobalVariableId])
  @@index([analyzedAt])
}

/// Population-level causal inference analysis aggregated across all subjects.
/// Each row answers: "Across ALL subjects, how does variable A predict variable B?"
/// legacy API reference: https://github.com/mikepsinn/curedao-api/blob/main/app/Models/AggregateCorrelation.php
/// legacy API analysis pipeline: https://github.com/mikepsinn/curedao-api/blob/main/app/Correlations/QMAggregateCorrelation.php
/// legacy API aggregates subject-level correlations via weighted averaging by statistical significance.
/// Weighted aggregation implemented in packages/optimizer/src/statistics.ts (aggregateNOf1VariableRelationships)
model AggregateVariableRelationship {
  /// Unique identifier for this aggregate-level relationship
  id String @id @default(cuid())

  /// The predictor (input/cause) variable in this relationship
  predictorGlobalVariableId String

  /// Relation to the predictor GlobalVariable
  predictorGlobalVariable GlobalVariable @relation("AggregateRelPredictorGlobal", fields: [predictorGlobalVariableId], references: [id])

  /// The outcome (effect/result) variable in this relationship
  outcomeGlobalVariableId String

  /// Relation to the outcome GlobalVariable
  outcomeGlobalVariable GlobalVariable @relation("AggregateRelOutcomeGlobal", fields: [outcomeGlobalVariableId], references: [id])

  // -- Statistical fields --

  /// Pearson correlation with predictor preceding outcome (expected causal direction)
  forwardPearsonCorrelation Float

  /// Pearson correlation with outcome preceding predictor — if reverse > forward,
  /// the assumed causal direction may be wrong
  reversePearsonCorrelation Float

  /// Spearman rank correlation (assesses monotonic relationships, linear or not)
  forwardSpearmanCorrelation Float?

  /// Statistical significance (< 0.05 = significant)
  pValue Float?

  /// Student's t-value (function of correlation and sample size)
  tValue Float?

  /// Threshold t-value from lookup table that t must exceed for significance
  criticalTValue Float?

  /// Margin of error around the effect size
  confidenceInterval Float?

  /// A function of the effect size and sample size
  statisticalSignificance Float?

  /// Standard deviations from the mean — z > 2 means p < 0.05
  zScore Float?

  /// Number of predictor-outcome measurement pairs used in the analysis
  numberOfPairs Int

  /// Number of days of data included in the analysis
  numberOfDays Int?

  /// Strongest Pearson correlation found across all onset delay permutations
  strongestPearsonCorrelation Float?

  /// Optimal Pearson product (correlation × statistical significance)
  optimalPearsonProduct Float?

  // -- Temporal parameters --

  /// Time after predictor measurement before a perceivable outcome change is observed (seconds)
  onsetDelay Int

  /// Time over which the predictor produces a perceivable outcome change following onset (seconds)
  durationOfAction Int

  /// The onset delay (seconds) that produced the strongest Pearson correlation
  onsetDelayWithStrongestCorrelation Int?

  // -- Outcome / prediction fields --

  /// Predictor value that predicts an above-average outcome (in predictor's default unit)
  valuePredictingHighOutcome Float?

  /// Predictor value that predicts a below-average outcome (in predictor's default unit)
  valuePredictingLowOutcome Float?

  /// Percent change in outcome typically seen when predictor value is high
  predictsHighOutcomeChange Int?

  /// Percent change in outcome typically seen when predictor value is low
  predictsLowOutcomeChange Int?

  /// Average outcome value across all measurements
  averageOutcome Float?

  /// Average outcome value following an above-average predictor value
  averageOutcomeFollowingHighPredictor Float?

  /// Average outcome value following a below-average predictor value
  averageOutcomeFollowingLowPredictor Float?

  /// Average daily predictor value on days associated with high outcome
  averageDailyHighPredictor Float?

  /// Average daily predictor value on days associated with low outcome
  averageDailyLowPredictor Float?

  /// Standardized effect size (Cohen's d or similar)
  effectSize Float?

  // -- Baseline / treatment comparison --

  /// Average daily predictor value during non-treatment (baseline) periods
  predictorBaselineAveragePerDay Float?

  /// Average daily predictor value during treatment periods
  predictorTreatmentAveragePerDay Float?

  /// Average outcome value during baseline (no treatment) periods
  outcomeBaselineAverage Float?

  /// Standard deviation of outcome during baseline periods
  outcomeBaselineStandardDeviation Float?

  /// Average outcome value during follow-up (post-treatment) periods
  outcomeFollowUpAverage Float?

  /// Percent change in outcome from baseline to follow-up
  outcomeFollowUpPercentChangeFromBaseline Float?

  // -- Quality / meta fields --

  /// Magnitude of the predictor-outcome relationship
  strengthLevel StrengthLevel?

  /// Confidence that this relationship will persist with more data
  confidenceLevel ConfidenceLevel?

  /// Direction: "POSITIVE" | "NEGATIVE" | "NONE"
  relationship RelationshipDirection?

  /// Predictor Impact Score — composite importance metric
  predictorImpactScore Float?

  /// Letter grade summarizing evidence quality: A/B/C/D/F
  evidenceGrade EvidenceGrade?

  /// Number of times the predictor measurement value changed from the preceding value
  predictorChanges Int?

  /// Number of times the outcome measurement value changed from the preceding value
  outcomeChanges Int?

  /// True if the relationship is obvious, uncontrollable, or too low confidence to be actionable
  trivial Boolean?

  /// True if the outcome variable is something the user wants to optimize
  outcomeIsGoal Boolean?

  /// True if the predictor variable is directly controllable by the user
  predictorIsControllable Boolean?

  /// True if there is a plausible mechanism of action for this relationship
  plausiblyCausal Boolean?

  /// The predictor value associated with the best outcome
  optimalValue Float?

  // -- Aggregate-specific fields --

  /// Number of subjects whose data contributed to this analysis
  numberOfSubjects Int

  /// Overall quality/importance score aggregated across subjects (QM score)
  aggregateQmScore Float?

  /// Community votes: how many users found this relationship useful
  numberOfUpVotes Int?

  /// Community votes: how many users found this relationship not useful
  numberOfDownVotes Int?

  /// When this analysis was last computed
  analyzedAt DateTime

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  @@unique([predictorGlobalVariableId, outcomeGlobalVariableId])
  @@index([predictorGlobalVariableId])
  @@index([outcomeGlobalVariableId])
  @@index([analyzedAt])
  @@index([numberOfSubjects])
