/// Subject-level n-of-1 causal inference analysis between two variables.
/// Each row answers: "For THIS subject, how does variable A predict variable B?"
/// legacy API reference: https://github.com/mikepsinn/curedao-api/blob/main/app/Models/Correlation.php
/// legacy API analysis pipeline: https://github.com/mikepsinn/curedao-api/blob/main/app/Correlations/QMUserCorrelation.php
/// legacy API calculation properties: https://github.com/mikepsinn/curedao-api/blob/main/app/Properties/Correlation/
model NOf1VariableRelationship {
  /// Unique identifier for this subject-level relationship
  id String @id @default(cuid())

  /// The analyzed subject (user, jurisdiction, cohort, etc.)
  subjectId String

  /// Relation to the analyzed Subject
  subject Subject @relation(fields: [subjectId], references: [id])

  /// The predictor (input/cause) variable in this relationship
  predictorGlobalVariableId String

  /// Relation to the predictor GlobalVariable
  predictorGlobalVariable GlobalVariable @relation("NOf1RelPredictorGlobal", fields: [predictorGlobalVariableId], references: [id])

  /// The outcome (effect/result) variable in this relationship
  outcomeGlobalVariableId String

  /// Relation to the outcome GlobalVariable
  outcomeGlobalVariable GlobalVariable @relation("NOf1RelOutcomeGlobal", fields: [outcomeGlobalVariableId], references: [id])

  // -- Statistical fields --

  /// Pearson correlation with predictor preceding outcome (expected causal direction)
  forwardPearsonCorrelation Float

  /// Pearson correlation with outcome preceding predictor — if reverse > forward,
  /// the assumed causal direction may be wrong
  reversePearsonCorrelation Float

  /// Spearman rank correlation (assesses monotonic relationships, linear or not)
  forwardSpearmanCorrelation Float?

  /// Statistical significance (< 0.05 = significant)
  pValue Float?

  /// Student's t-value (function of correlation and sample size)
  tValue Float?

  /// Threshold t-value from lookup table that t must exceed for significance
  criticalTValue Float?

  /// Margin of error around the effect size
  confidenceInterval Float?

  /// A function of the effect size and sample size
  statisticalSignificance Float?

  /// Standard deviations from the mean — z > 2 means p < 0.05
  zScore Float?

  /// Number of predictor-outcome measurement pairs used in the analysis
  numberOfPairs Int

  /// Number of days of data included in the analysis
  numberOfDays Int?

  /// Strongest Pearson correlation found across all onset delay permutations
  strongestPearsonCorrelation Float?

  /// Optimal Pearson product (correlation × statistical significance)
  optimalPearsonProduct Float?

  // -- Temporal parameters --

  /// Time after predictor measurement before a perceivable outcome change is observed (seconds)
  onsetDelay Int

  /// Time over which the predictor produces a perceivable outcome change following onset (seconds)
  durationOfAction Int

  /// The onset delay (seconds) that produced the strongest Pearson correlation
  onsetDelayWithStrongestCorrelation Int?

  // -- Outcome / prediction fields --

  /// Predictor value that predicts an above-average outcome (in predictor's default unit)
  valuePredictingHighOutcome Float?

  /// Predictor value that predicts a below-average outcome (in predictor's default unit)
  valuePredictingLowOutcome Float?

  /// Percent change in outcome typically seen when predictor value is high
  predictsHighOutcomeChange Int?

  /// Percent change in outcome typically seen when predictor value is low
  predictsLowOutcomeChange Int?

  /// Average outcome value across all measurements
  averageOutcome Float?

  /// Average outcome value following an above-average predictor value
  averageOutcomeFollowingHighPredictor Float?

  /// Average outcome value following a below-average predictor value
  averageOutcomeFollowingLowPredictor Float?

  /// Average daily predictor value on days associated with high outcome
  averageDailyHighPredictor Float?

  /// Average daily predictor value on days associated with low outcome
  averageDailyLowPredictor Float?

  /// Standardized effect size (Cohen's d or similar)
  effectSize Float?

  // -- Baseline / treatment comparison --

  /// Average daily predictor value during non-treatment (baseline) periods
  predictorBaselineAveragePerDay Float?

  /// Average daily predictor value during treatment periods
  predictorTreatmentAveragePerDay Float?

  /// Average outcome value during baseline (no treatment) periods
  outcomeBaselineAverage Float?

  /// Standard deviation of outcome during baseline periods
  outcomeBaselineStandardDeviation Float?

  /// Average outcome value during follow-up (post-treatment) periods
  outcomeFollowUpAverage Float?

  /// Percent change in outcome from baseline to follow-up
  outcomeFollowUpPercentChangeFromBaseline Float?

  // -- Quality / meta fields --

  /// Magnitude of the predictor-outcome relationship
  strengthLevel StrengthLevel?

  /// Confidence that this relationship will persist with more data
  confidenceLevel ConfidenceLevel?

  /// Direction: "POSITIVE" | "NEGATIVE" | "NONE"
  relationship RelationshipDirection?

  /// Predictor Impact Score — composite importance metric
  predictorImpactScore Float?

  /// Letter grade summarizing evidence quality: A/B/C/D/F
  evidenceGrade EvidenceGrade?

  /// Number of times the predictor measurement value changed from the preceding value
  predictorChanges Int?

  /// Number of times the outcome measurement value changed from the preceding value
  outcomeChanges Int?

  /// True if the relationship is obvious, uncontrollable, or too low confidence to be actionable
  trivial Boolean?

  /// True if the outcome variable is something the user wants to optimize
  outcomeIsGoal Boolean?

  /// True if the predictor variable is directly controllable by the user
  predictorIsControllable Boolean?

  /// True if there is a plausible mechanism of action for this relationship
  plausiblyCausal Boolean?

  /// The predictor value associated with the best outcome
  optimalValue Float?

  /// When this analysis was last computed
  analyzedAt DateTime

  /// When this record was created
  createdAt DateTime @default(now())

  /// When this record was last updated
  updatedAt DateTime @updatedAt

  /// Soft-delete timestamp; non-null means this record is logically deleted
  deletedAt DateTime?

  @@unique([subjectId, predictorGlobalVariableId, outcomeGlobalVariableId])
  @@index([subjectId])
  @@index([predictorGlobalVariableId])
  @@index([outcomeGlobalVariableId])
  @@index([analyzedAt])
}

