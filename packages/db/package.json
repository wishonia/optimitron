{
  "name": "@optimitron/db",
  "version": "0.1.0",
  "description": "Prisma schema and database client for Wishocracy",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:integration": "tsx src/run-local-db-tests.ts",
    "test:watch": "vitest",
    "db:cli": "tsx src/db-cli.ts",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma",
    "seed": "prisma db seed",
    "seed:reference": "tsx prisma/seed.ts --scope reference",
    "seed:bootstrap": "tsx prisma/seed.ts --scope bootstrap",
    "seed:demo": "tsx prisma/seed.ts --scope demo"
  },
  "dependencies": {
    "@optimitron/data": "workspace:*",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prisma": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
