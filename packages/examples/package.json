{
  "name": "@optimitron/examples",
  "version": "0.1.0",
  "private": true,
  "description": "Worked examples — federal budget, causal analysis, alignment scoring",
  "type": "module",
  "scripts": {
    "build:deps": "pnpm --filter @optimitron/examples^... build",
    "demo:health": "pnpm run build:deps && tsx src/golden-path/health-optimization-demo.ts",
    "demo:budget": "pnpm run build:deps && tsx src/federal-budget-demo.ts",
    "demo:causal": "pnpm run build:deps && tsx src/causal-analysis-demo.ts",
    "demo:alignment": "pnpm run build:deps && tsx src/alignment-demo.ts",
    "generate:budget": "pnpm run build:deps && tsx src/us-federal-analysis/generate-budget-analysis.ts",
    "generate:drug-war-overdose": "pnpm run build:deps && tsx src/us-federal-analysis/generate-drug-war-overdose-analysis.ts",
    "generate:government-size": "pnpm run build:deps && tsx src/us-federal-analysis/generate-government-size-analysis.ts",
    "generate:government-spending-metrics": "pnpm run build:deps && tsx src/us-federal-analysis/generate-government-spending-metric-comparison.ts",
    "generate:policy": "pnpm run build:deps && tsx src/us-federal-analysis/generate-policy-analysis.ts",
    "generate:mega-studies": "pnpm run build:deps && tsx src/analysis-explorer/generate-mega-studies.ts",
    "review:mega-studies": "pnpm run build:deps && tsx src/analysis-explorer/review-mega-study-output.ts",
    "generate:mega-studies:reviewed": "pnpm run generate:mega-studies && pnpm run review:mega-studies",
    "generate:drug-war-proxy-aggregated": "pnpm run build:deps && tsx src/analysis-explorer/generate-drug-war-proxy-aggregated-study.ts",
    "generate:drug-enforcement-aggregated": "pnpm run build:deps && tsx src/analysis-explorer/generate-drug-enforcement-aggregated-comparison.ts",
    "generate:drug-enforcement-aggregated-comparison": "pnpm run build:deps && tsx src/analysis-explorer/generate-drug-enforcement-aggregated-comparison.ts",
    "generate:health": "pnpm run build:deps && tsx src/international-analysis/generate-health-comparison.ts",
    "generate:drug-policy": "pnpm run build:deps && tsx src/international-analysis/generate-drug-policy-comparison.ts",
    "generate:education": "pnpm run build:deps && tsx src/international-analysis/generate-education-comparison.ts",
    "generate:cross-country": "pnpm run build:deps && tsx src/international-analysis/generate-cross-country-analysis.ts",
    "generate:web-data": "tsx src/generate-web-data.ts",
    "generate:site": "tsx src/generate-site-reports.ts",
    "test": "pnpm run build:deps && vitest run",
    "test:integration": "pnpm run build:deps && vitest run src/integration-tests/"
  },
  "dependencies": {
    "zod": "^3.22.4",
    "@optimitron/agent": "workspace:*",
    "@optimitron/data": "workspace:*",
    "@optimitron/hypercerts": "workspace:*",
    "@optimitron/obg": "workspace:*",
    "@optimitron/opg": "workspace:*",
    "@optimitron/optimizer": "workspace:*",
    "@optimitron/storage": "workspace:*",
    "@optimitron/wishocracy": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
