# Optomitron Environment Variables
# Copy to .env and fill in values. NEVER commit .env!

# Database (required for @optomitron/db)
# Matches the local Docker Compose Postgres service.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/optomitron

# Web auth/app URLs
# For local dev with packages/web on port 3000.
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-this-with-a-long-random-secret

# Email / auth providers for packages/web
RESEND_API_KEY=replace-this-with-your-resend-api-key
EMAIL_FROM=Optomitron <auth@example.com>
GOOGLE_CLIENT_ID=replace-this-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-this-with-google-client-secret

# Background jobs
CRON_SECRET=replace-this-with-a-random-cron-secret
REFERRAL_EMAIL_BATCH_SIZE=50

# Client auth UX toggles
NEXT_PUBLIC_MAGIC_LINK_ENABLED=true
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true

# Data fetcher API keys (optional, for @optomitron/data)
FRED_API_KEY=
WORLD_BANK_API_KEY=
CONGRESS_API_KEY=

# OpenClaw (for agent notifications)
OPENCLAW_TOKEN=
