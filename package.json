{
  "name": "optomitron",
  "version": "0.1.0",
  "private": true,
  "description": "Optimal Policy & Budget Generator - Evidence-based governance calculations",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikepsinn/optomitron.git"
  },
  "author": "Mike P. Sinn <m@thinkbynumbers.org>",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "report": "pnpm --filter @optomitron/core report"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@8.14.0",
  "engines": {
    "node": ">=18"
  }
}
