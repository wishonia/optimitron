{
  "name": "optimitron",
  "version": "0.1.0",
  "private": true,
  "description": "The Earth Optimization Game: causal inference, preference aggregation, health tracking, optimal policy & budget generation",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikepsinn/optimitron.git"
  },
  "author": "Mike P. Sinn <m@thinkbynumbers.org>",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @optimitron/web dev",
    "dev:wishonia": "pnpm --filter @optimitron/wishonia dev",
    "build": "pnpm -r build",
    "postinstall": "pnpm --filter @optimitron/db prisma:generate",
    "test": "pnpm -r test",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "db:generate": "pnpm --filter @optimitron/db run prisma:generate",
    "db:validate": "pnpm --filter @optimitron/db run prisma:validate",
    "db:cli": "pnpm --filter @optimitron/db exec tsx src/db-cli.ts",
    "db:migrate": "pnpm --filter @optimitron/db run prisma:migrate:dev",
    "db:deploy": "pnpm --filter @optimitron/db run prisma:migrate:deploy",
    "db:push": "pnpm --filter @optimitron/db run prisma:push",
    "db:seed": "pnpm --filter @optimitron/db run seed",
    "db:up": "docker compose up -d --wait postgres",
    "db:setup": "pnpm db:up && pnpm db:deploy && pnpm db:generate && pnpm db:seed",
    "db:reset": "docker compose down -v && pnpm db:setup",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "alignment:sync": "pnpm --filter @optimitron/web run sync:alignment-politicians",
    "review:mega-studies": "pnpm --filter @optimitron/examples run review:mega-studies",
    "review:test-output": "pnpm --filter @optimitron/agent run review:test-output --",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "packages/*/src/**/*.ts": [
      "npx eslint --fix --no-warn-ignored"
    ],
    "packages/db/prisma/**/*.prisma": [
      "pnpm --filter @optimitron/db exec prisma validate",
      "pnpm --filter @optimitron/db exec prisma format"
    ]
  },
  "packageManager": "pnpm@8.14.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "glob@>=10.2.0 <10.5.0": ">=10.5.0"
    }
  }
}
